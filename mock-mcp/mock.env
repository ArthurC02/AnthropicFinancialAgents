# CMA / Claude Managed Agent MCP wiring (POSIX shell / .env).
# Usage: start servers with `python mock-mcp/run_all_http.py`, then `source mock-mcp/mock.env`.
# These are the values the cookbook agent.yaml ${..._MCP_URL} placeholders resolve to.
# All mock / dev, pointing at the local streamable-http servers.

export GL_MCP_URL=http://127.0.0.1:8001/mcp          # internal-gl  (gl-reconciler, month-end-closer)
export SUBLEDGER_MCP_URL=http://127.0.0.1:8002/mcp   # subledger    (gl-reconciler)
export PORTFOLIO_MCP_URL=http://127.0.0.1:8003/mcp   # portfolio    (valuation-reviewer)
export NAV_MCP_URL=http://127.0.0.1:8004/mcp         # nav          (statement-auditor)
export CRM_MCP_URL=http://127.0.0.1:8005/mcp         # crm          (meeting-prep-agent)
export SCREENING_MCP_URL=http://127.0.0.1:8006/mcp   # screening    (kyc-screener)
export CAPIQ_MCP_URL=http://127.0.0.1:8007/mcp       # capiq        (market-researcher, model-builder, pitch-agent, meeting-prep-agent)

# factset / daloopa: shipped config uses the real vendor URLs (need credentials).
# For fully offline testing, uncomment these and start 8008/8009 via run_all_http.py:
# export FACTSET_MCP_URL=http://127.0.0.1:8008/mcp   # factset (earnings-reviewer, market-researcher)
# export DALOOPA_MCP_URL=http://127.0.0.1:8009/mcp   # daloopa (earnings-reviewer, model-builder, pitch-agent)
